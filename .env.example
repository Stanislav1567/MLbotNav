SOURCE_ENV_PATH=C:\path\to\external\project\.env

# Optional local overrides
BYBIT_BASE_URL=
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_CATEGORY=linear
BYBIT_RECV_WINDOW=20000

SYMBOL=SOLUSDT
TIMEFRAMES=1,5,15,30,60,240,D

# Storage backend: file | postgres
STORAGE_MODE=file
# Example: postgresql://user:pass@localhost:5432/mlbotnav
POSTGRES_DSN=
# Optuna storage (RDB). If empty, runtime may fallback to sqlite.
OPTUNA_STORAGE_URL=

# Security provider and gate related values
MLBOTNAV_SIGNING_KEY=
VAULT_ADDR=
KMS_KEY_ID=
STORAGE_ENCRYPTION_ENABLED=false
